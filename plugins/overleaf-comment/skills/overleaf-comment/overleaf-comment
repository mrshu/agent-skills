#!/usr/bin/env bash
# overleaf-comment — bulk-post Overleaf comments from a JSON plan via CDP.
#
# Usage:
#   overleaf-comment <target> <plan.json>
#   overleaf-comment --url <project-url> <plan.json>
#   overleaf-comment --list
#
# Plan format (JSON array):
#   [
#     {"file": "main.tex", "line": 8, "text": "..."},
#     {"file": "parts/200-discussion.tex", "line": 108, "text": "..."}
#   ]
#
# <target> is a unique CDP target prefix from `cdp list` (e.g. 6172EEAA).
# The Overleaf tab must already be open and logged in.
#
# Architecture: helpers are injected once into the tab, then the wrapper
# iterates plan items one cdp eval at a time. Each eval finishes well under
# chrome-cdp's 15 s Runtime.evaluate ceiling, and results stream to stdout
# as they happen so partial progress is always visible.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
HELPERS="$SCRIPT_DIR/page-helpers.js"

# Hostnames whose `/project/<hex>` URLs identify Overleaf project tabs.
# Override (e.g. self-hosted Overleaf) by setting OVERLEAF_HOSTS to a
# space-separated list, or by passing --url which is host-agnostic.
OVERLEAF_HOSTS="${OVERLEAF_HOSTS:-overleaf.com www.overleaf.com}"

# python3 is required for plan validation. Probe up front so the user gets a
# clear message rather than a "command not found" deep inside a heredoc.
command -v python3 >/dev/null 2>&1 || {
  echo "overleaf-comment: python3 is required (used for plan validation)." >&2
  exit 2
}

# ---------------------------------------------------------------------------
# Resolve cdp.mjs from the chrome-cdp skill in priority order.
# ---------------------------------------------------------------------------
resolve_cdp() {
  if [ -n "${CDP_BIN:-}" ]; then
    if [ -x "$CDP_BIN" ]; then
      echo "$CDP_BIN"; return
    fi
    echo "overleaf-comment: CDP_BIN points to '$CDP_BIN' but it is not executable." >&2
    exit 2
  fi
  if command -v cdp.mjs >/dev/null 2>&1; then
    command -v cdp.mjs; return
  fi
  # Use a subshell so `nullglob` does not leak into the caller's environment.
  (
    shopt -s nullglob
    local candidates=(
      "$HOME/.claude/skills/chrome-cdp/scripts/cdp.mjs"
      "$HOME"/.claude/plugins/*/skills/chrome-cdp/scripts/cdp.mjs
      "$SCRIPT_DIR/../../../chrome-cdp/skills/chrome-cdp/scripts/cdp.mjs"
      "${CLAUDE_PLUGIN_ROOT:-/var/empty}/../chrome-cdp/skills/chrome-cdp/scripts/cdp.mjs"
    )
    for c in "${candidates[@]}"; do
      [ -x "$c" ] && { echo "$c"; exit 0; }
    done
  )
}

CDP="$(resolve_cdp)"
if [ -z "$CDP" ]; then
  cat >&2 <<'EOF'
overleaf-comment: chrome-cdp not found.

Install the chrome-cdp skill (or set CDP_BIN=/path/to/cdp.mjs).
Searched: $CDP_BIN, PATH, ~/.claude/skills/chrome-cdp/, ~/.claude/plugins/*/skills/chrome-cdp/, sibling skills.
EOF
  exit 2
fi

USAGE_TEXT='overleaf-comment — bulk-post Overleaf comments from a JSON plan via CDP.

Usage:
  overleaf-comment <target> <plan.json>
  overleaf-comment --url <project-url> <plan.json>
  overleaf-comment --list

Plan format (JSON array of {file, line, text}):
  [
    {"file": "main.tex", "line": 8, "text": "..."},
    {"file": "parts/200-discussion.tex", "line": 108, "text": "..."}
  ]

<target> is a unique CDP target prefix from `cdp list` (e.g. 6172EEAA).
The Overleaf tab must already be open and logged in.'

usage() { printf '%s\n' "$USAGE_TEXT"; exit "${1:-0}"; }

# ---------------------------------------------------------------------------
# Parse args
# ---------------------------------------------------------------------------
TARGET=""
URL=""
PLAN=""
LIST=0
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage 0 ;;
    --list) LIST=1; shift ;;
    --url)
      if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
        echo "overleaf-comment: --url requires a value" >&2
        usage 2 >&2
      fi
      URL="$2"; shift 2 ;;
    --) shift; break ;;
    -*) echo "overleaf-comment: unknown flag: $1" >&2; usage 2 >&2 ;;
    *)
      # Always assign positionals in order TARGET → PLAN (regardless of
      # whether --url was already passed) so the explicit "mutually
      # exclusive" check below can fire with a clear message.
      if [ -z "$TARGET" ]; then TARGET="$1"
      elif [ -z "$PLAN" ]; then PLAN="$1"
      else echo "overleaf-comment: unexpected arg: $1" >&2; usage 2 >&2
      fi
      shift ;;
  esac
done

if [ -n "$URL" ] && [ -n "$TARGET" ]; then
  # When --url is set, the first positional was meant to be the plan; if a
  # second positional also showed up, the user gave both --url AND a target
  # prefix.
  if [ -n "$PLAN" ]; then
    echo "overleaf-comment: --url and <target> are mutually exclusive" >&2
    exit 2
  fi
  PLAN="$TARGET"
  TARGET=""
fi

# ---------------------------------------------------------------------------
# --list: show overleaf project tabs, exit. Filter by host so self-hosted
# Overleaf instances (set OVERLEAF_HOSTS) are recognised.
# ---------------------------------------------------------------------------
if [ "$LIST" = 1 ]; then
  CDP_OUT="$("$CDP" list 2>&1)" || {
    echo "overleaf-comment: failed to query browser via cdp.mjs:" >&2
    printf '%s\n' "$CDP_OUT" >&2
    exit 1
  }
  # Match by literal substring (`awk index()`) instead of building a regex
  # from user input, so dots in hostnames stay literal and a stray
  # OVERLEAF_HOSTS value can't inject regex metacharacters.
  matches="$(printf '%s\n' "$CDP_OUT" | awk -v hosts="$OVERLEAF_HOSTS" '
    BEGIN { n = split(hosts, h, " "); for (i=1; i<=n; i++) p[i] = h[i] "/project/" }
    { for (i=1; i<=n; i++) if (index($0, p[i])) { print; next } }
  ')"
  if [ -z "$matches" ]; then
    echo "overleaf-comment: no Overleaf project tabs are open" >&2
    echo "  (looked for hosts: $OVERLEAF_HOSTS — override with OVERLEAF_HOSTS env var)" >&2
    exit 1
  fi
  printf '%s\n' "$matches"
  exit 0
fi

# ---------------------------------------------------------------------------
# Resolve target from --url if needed. Match against the URL column of
# `cdp list` via `index()` so a stray project id appearing in another
# tab's title can't false-positive.
# ---------------------------------------------------------------------------
if [ -z "$TARGET" ] && [ -n "$URL" ]; then
  PID="$(echo "$URL" | sed -nE 's#.*/project/([0-9a-fA-F]+).*#\1#p' | tr 'A-F' 'a-f')"
  if [ -z "$PID" ]; then
    echo "overleaf-comment: could not extract project id from --url $URL" >&2
    exit 2
  fi
  CDP_OUT="$("$CDP" list 2>&1)" || {
    echo "overleaf-comment: failed to query browser via cdp.mjs:" >&2
    printf '%s\n' "$CDP_OUT" >&2
    exit 1
  }
  # `cdp list` prints `<prefix>  <title>  <url>` with the URL last.
  MATCHES="$(printf '%s\n' "$CDP_OUT" | awk -v pat="/project/$PID" 'index($NF, pat) {print $1}')"
  # `wc -l` always prints exactly one number; piping through `tr` collapses
  # the leading whitespace BSD wc emits.
  N_MATCHES="$(printf '%s' "$MATCHES" | grep -c . 2>/dev/null || true)"
  N_MATCHES="${N_MATCHES:-0}"
  if [ "$N_MATCHES" = "0" ]; then
    echo "overleaf-comment: no open tab matches project id $PID" >&2
    echo "Open the project in your browser first, then re-run." >&2
    exit 1
  fi
  if [ "$N_MATCHES" != "1" ]; then
    echo "overleaf-comment: $N_MATCHES tabs match project id $PID:" >&2
    printf '%s\n' "$CDP_OUT" | awk -v pat="/project/$PID" 'index($NF, pat)' >&2
    echo "Pass one of the prefixes above explicitly instead of --url." >&2
    exit 1
  fi
  TARGET="$MATCHES"
fi

if [ -z "$TARGET" ] || [ -z "$PLAN" ]; then
  echo "overleaf-comment: <target> and <plan.json> are required (or --url and <plan.json>)" >&2
  usage 2 >&2
fi

if [ ! -f "$PLAN" ]; then
  echo "overleaf-comment: plan not found: $PLAN" >&2
  exit 2
fi

# ---------------------------------------------------------------------------
# Validate the plan and emit a tab-separated work list to a temp file.
# Heavy lifting is in plan_tools.py (see that file for the work-list
# format).
# ---------------------------------------------------------------------------
WORK="$(mktemp "${TMPDIR:-/tmp}/overleaf-comment.XXXXXX")" || {
  echo "overleaf-comment: could not create temp file" >&2; exit 2;
}
RESIDUAL_NDJSON="$(mktemp "${TMPDIR:-/tmp}/overleaf-comment.XXXXXX")" || {
  echo "overleaf-comment: could not create temp file" >&2; exit 2;
}
trap 'rm -f "$WORK" "$WORK.err" "$RESIDUAL_NDJSON"' EXIT

python3 "$SCRIPT_DIR/plan_tools.py" validate "$PLAN" "$WORK" || exit "$?"

# ---------------------------------------------------------------------------
# Bring the tab to the foreground. Chrome aggressively throttles setTimeout
# (and other async APIs) on background tabs, which causes our DOM-polling
# helpers to hang for many seconds and trip chrome-cdp's 15 s eval timeout.
# Page.bringToFront makes the tab visible so timers run at full speed.
# ---------------------------------------------------------------------------
"$CDP" evalraw "$TARGET" Page.bringToFront >/dev/null 2>&1 || true

# ---------------------------------------------------------------------------
# Inject helpers and verify they are reachable.
# ---------------------------------------------------------------------------
HELPERS_JS="$(cat "$HELPERS")"
inject_helpers() {
  if ! "$CDP" eval "$TARGET" "$HELPERS_JS" >/dev/null 2>"$WORK.err"; then
    echo "overleaf-comment: failed to inject helpers into the tab:" >&2
    cat "$WORK.err" >&2
    rm -f "$WORK.err"
    exit 1
  fi
  rm -f "$WORK.err"
  PROBE="$("$CDP" eval "$TARGET" 'typeof window.__overleaf' 2>&1 || true)"
  if [ "$PROBE" != "object" ]; then
    echo "overleaf-comment: helpers did not register on the tab (got: $PROBE)" >&2
    echo "  This usually means the tab navigated or reloaded between injections." >&2
    exit 1
  fi
}
inject_helpers

# One-shot preflight: tab visibility + active user + UI language in a
# single cdp eval. Returns line-delimited values to avoid having to parse
# cdp.mjs's pretty-printed JSON.
PREFLIGHT_OUT="$("$CDP" eval "$TARGET" '(() => {
  const p = window.__overleaf.preflight();
  return [p.hidden ? "hidden" : "visible", p.user || "", p.lang || ""].join("\n");
})()' 2>&1 || true)"
VIS="$(printf '%s\n' "$PREFLIGHT_OUT" | sed -n '1p')"
PFUSER="$(printf '%s\n' "$PREFLIGHT_OUT" | sed -n '2p')"
PFLANG="$(printf '%s\n' "$PREFLIGHT_OUT" | sed -n '3p')"

if [ "$VIS" = "hidden" ]; then
  echo "overleaf-comment: Overleaf tab still reports document.hidden=true after Page.bringToFront." >&2
  echo "  Chrome throttles setTimeout in background tabs; manually focus the tab and re-run." >&2
  exit 75   # EX_TEMPFAIL
fi

case "$PFUSER" in
  ""|null|undefined) echo "overleaf-comment: posting as Overleaf account: <unknown>" >&2 ;;
  *) echo "overleaf-comment: posting as Overleaf account: $PFUSER" >&2 ;;
esac

case "$PFLANG" in
  ""|en) : ;;
  *) echo "overleaf-comment: warning — Overleaf UI language is '$PFLANG'; this skill needs English UI strings." >&2 ;;
esac

# Pre-flight: dismiss any "Out of sync" modal before starting.
PREFLIGHT="$("$CDP" eval "$TARGET" '(async () => await window.__overleaf.dismissModals())()' 2>&1 || true)"
if [ "$PREFLIGHT" = "reloaded" ]; then
  echo "overleaf-comment: editor was 'Out of sync' — clicked Reload editor." >&2
  echo "Wait for the editor to settle, then re-run with the same plan." >&2
  exit 75   # EX_TEMPFAIL
fi

# ---------------------------------------------------------------------------
# Iterate the work list, streaming results to stdout. Failed / skipped
# items are appended to RESIDUAL_NDJSON as one JSON object per line; at
# the end plan_tools.py turns that into a proper residual plan file.
# ---------------------------------------------------------------------------
exit_code=0
file_failed=0
ok_count=0
fail_count=0
skip_count=0
current_file_js=""

# Append one residual entry. All values are already JSON-encoded by the
# work-list emitter, so a literal printf produces a valid JSON line.
push_residual() {
  printf '{"file":%s,"line":%s,"text":%s}\n' \
    "$current_file_js" "$1" "$2" >> "$RESIDUAL_NDJSON"
}

while IFS=$'\t' read -r kind a b; do
  case "$kind" in
    OPEN)
      current_file_js="$b"
      result="$("$CDP" eval "$TARGET" "(async () => await window.__overleaf.openFile($b))()" 2>&1 || true)"
      printf '[%s] %s\n' "$a" "$result"
      if [[ "$result" == OK:* ]]; then
        file_failed=0
      else
        file_failed=1
        exit_code=1
      fi
      ;;
    POST)
      if [ "$file_failed" = 1 ]; then
        printf '  L%s: SKIP: file open failed\n' "$a"
        skip_count=$((skip_count + 1))
        push_residual "$a" "$b"
        exit_code=1
        continue
      fi
      result="$("$CDP" eval "$TARGET" "(async () => await window.__overleaf.post($a, $b))()" 2>&1 || true)"

      # Files where the static toolbar Add-comment button is absent
      # (.bib / .bst / .cls / .sty …) require a real PointerEvent-driven
      # selection to mount Overleaf's floating Add-comment popover. The
      # page helper returns DRAG_NEEDED:{x1,x2,y,line}; the wrapper
      # synthesises the mouse drag via CDP Input domain and then calls
      # completePopoverPost which finishes the post.
      if [[ "$result" == DRAG_NEEDED:* ]]; then
        coords="${result#DRAG_NEEDED:}"
        x1=$(printf '%s' "$coords" | python3 -c 'import sys,json;d=json.load(sys.stdin);print(d["x1"])' 2>/dev/null || echo "")
        x2=$(printf '%s' "$coords" | python3 -c 'import sys,json;d=json.load(sys.stdin);print(d["x2"])' 2>/dev/null || echo "")
        y=$(printf '%s' "$coords" | python3 -c 'import sys,json;d=json.load(sys.stdin);print(d["y"])' 2>/dev/null || echo "")
        if [ -z "$x1" ] || [ -z "$x2" ] || [ -z "$y" ]; then
          printf '  L%s: FAIL: helper returned malformed DRAG_NEEDED coords\n' "$a"
          fail_count=$((fail_count + 1))
          push_residual "$a" "$b"
          exit_code=1
          continue
        fi
        x_mid=$(( (x1 + x2) / 2 ))
        # Trusted mouse drag: press at line start, move to mid then end,
        # release at end. The intermediate move is what flips Overleaf's
        # selection state from "click" to "drag" — without it the
        # popover sometimes doesn't mount.
        "$CDP" evalraw "$TARGET" Input.dispatchMouseEvent \
          "{\"type\":\"mousePressed\",\"x\":$x1,\"y\":$y,\"button\":\"left\",\"clickCount\":1}" >/dev/null 2>&1
        "$CDP" evalraw "$TARGET" Input.dispatchMouseEvent \
          "{\"type\":\"mouseMoved\",\"x\":$x_mid,\"y\":$y,\"button\":\"left\",\"buttons\":1}" >/dev/null 2>&1
        "$CDP" evalraw "$TARGET" Input.dispatchMouseEvent \
          "{\"type\":\"mouseMoved\",\"x\":$x2,\"y\":$y,\"button\":\"left\",\"buttons\":1}" >/dev/null 2>&1
        "$CDP" evalraw "$TARGET" Input.dispatchMouseEvent \
          "{\"type\":\"mouseReleased\",\"x\":$x2,\"y\":$y,\"button\":\"left\",\"clickCount\":1}" >/dev/null 2>&1
        result="$("$CDP" eval "$TARGET" "(async () => await window.__overleaf.completePopoverPost($a, $b))()" 2>&1 || true)"
      fi

      printf '  L%s: %s\n' "$a" "$result"
      if [[ "$result" == RELOADED:* ]]; then
        echo "overleaf-comment: editor reloaded mid-run — aborting." >&2
        push_residual "$a" "$b"
        exit_code=75
        break
      fi
      if [[ "$result" == OK:* ]]; then
        ok_count=$((ok_count + 1))
      else
        fail_count=$((fail_count + 1))
        push_residual "$a" "$b"
        exit_code=1
      fi
      ;;
  esac
done < "$WORK"

# ---------------------------------------------------------------------------
# Summary + residual plan emission.
# ---------------------------------------------------------------------------
total=$((ok_count + fail_count + skip_count))
printf 'summary: %d ok / %d fail / %d skip (%d total)\n' \
  "$ok_count" "$fail_count" "$skip_count" "$total" >&2

# Emit a residual plan if any items did not post.
if [ -s "$RESIDUAL_NDJSON" ]; then
  # `${PLAN%.json}.residual.json` strips a single trailing `.json`. If
  # PLAN doesn't end in `.json` the result equals `${PLAN}.residual.json`
  # — fine.
  case "$PLAN" in
    *.json) RESIDUAL="${PLAN%.json}.residual.json" ;;
    *)      RESIDUAL="${PLAN}.residual.json" ;;
  esac
  # If a residual from a previous run is already there, back it up rather
  # than silently overwriting.
  if [ -e "$RESIDUAL" ] && [ "$RESIDUAL" != "$PLAN" ]; then
    mv "$RESIDUAL" "$RESIDUAL.$(date +%s).bak"
  fi
  # Refuse to overwrite the input plan itself.
  if [ "$RESIDUAL" = "$PLAN" ]; then
    RESIDUAL="${PLAN}.residual.json"
  fi
  python3 "$SCRIPT_DIR/plan_tools.py" residual "$RESIDUAL_NDJSON" "$RESIDUAL"
  echo "overleaf-comment: residual plan written to $RESIDUAL ($fail_count failed + $skip_count skipped)" >&2
fi

exit "$exit_code"
